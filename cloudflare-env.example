# Cloudflare Worker/Page variables
NEXT_PUBLIC_APP_NAME=Casi Bros PM

# Required Cloudflare bindings
DB=Cloudflare D1 database binding configured in wrangler.toml
PROJECT_FILES=R2 bucket binding for project attachments
NEXT_INC_CACHE_R2_BUCKET=R2 bucket binding for OpenNext incremental cache
WORKER_SELF_REFERENCE=Service binding to project-mgmt-cb
NEXT_ASSETS=Static asset binding generated by OpenNext
IMAGES=Cloudflare Images binding
